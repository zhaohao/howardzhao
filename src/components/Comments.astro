---
/* src/components/Comments.astro */
---

<div class="mt-8">
  <div id="artalk-comments"></div>
</div>

<link href="https://artalk.howardzhao.com/dist/Artalk.css" rel="stylesheet">
<script src="https://artalk.howardzhao.com/dist/Artalk.js"></script>

<script is:inline>
  function initArtalk() {
    const el = document.querySelector('#artalk-comments');
    if (!el || typeof Artalk === 'undefined') return;

    // 1. 获取当前 AstroPaper 的主题状态
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    // 2. 实例化
    const artalk = Artalk.init({
      el: '#artalk-comments',
      pageKey: window.location.pathname,
      pageTitle: document.title,
      server: 'https://artalk.howardzhao.com', // 替换为你的服务器地址
      site: 'HZ',
      darkMode: isDark,
    });

    // 3. 监听主题切换按钮 (AstroPaper 专属 ID)
    const themeBtn = document.querySelector('#theme-btn');
    if (themeBtn) {
      themeBtn.addEventListener('click', () => {
        // 给个微小的延迟，等待 AstroPaper 切换 data-theme
        setTimeout(() => {
          const nowDark = document.documentElement.getAttribute('data-theme') === 'dark';
          artalk.setDarkMode(nowDark);
        }, 50);
      });
    }

    // 4. 将实例挂载到 window，方便调试或防止重复初始化
    window.artalkInstance = artalk;
  }

  // 响应 Astro 视图切换
  document.addEventListener('astro:page-load', () => {
    // 如果已有实例，先销毁旧的
    if (window.artalkInstance) {
        window.artalkInstance.destroy();
    }
    initArtalk();
  });
</script>

<style is:global>
  /* 基础变量配置 */
  .artalk {
    --at-color-font: rgb(var(--color-text-base));
    --at-color-bg: rgb(var(--color-fill));
    --at-color-main: rgb(var(--color-accent));
    --at-color-border: rgba(var(--color-text-base), 0.1);
    --at-color-light: rgb(var(--color-card-muted));
    --at-color-grey: rgb(var(--color-text-muted));
  }

  /* 修复 Tailwind v4 下的编译错误 */
  .atk-main-editor {
    /* 使用 @apply 处理基础样式 */
    @apply border border-skin-line rounded-lg;
    /* 必须加 important 的样式，写在原生 CSS 属性后 */
    background: transparent !important;
    border-color: rgb(var(--color-line)) !important;
  }

  .atk-send-btn {
    @apply font-bold;
    border-radius: 4px !important;
  }

  /* 针对暗黑模式的强制微调 */
  [data-theme="dark"] .artalk {
    --at-color-bg: rgb(var(--color-fill));
    --at-color-light: rgba(255, 255, 255, 0.05);
  }

  /* 解决输入框文字颜色可能看不清的问题 */
  .atk-header-item input {
    color: rgb(var(--color-text-base)) !important;
  }
</style>