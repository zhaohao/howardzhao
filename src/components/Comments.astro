---
/* src/components/Comments.astro */
---

<div class="mt-8">
  <div id="artalk-comments"></div>
</div>

<link href="https://artalk.howardzhao.com/dist/Artalk.css" rel="stylesheet">
<script src="https://artalk.howardzhao.com/dist/Artalk.js"></script>

<script is:inline>
  function initArtalk() {
    const el = document.querySelector('#artalk-comments');
    if (!el || typeof Artalk === 'undefined') return;

    // 1. 获取当前 AstroPaper 的主题状态
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    // 2. 实例化
    const artalk = Artalk.init({
      el: '#artalk-comments',
      pageKey: window.location.pathname,
      pageTitle: document.title,
      server: 'https://artalk.howardzhao.com', // 替换为你的服务器地址
      site: 'HZ',
      darkMode: isDark,
    });

    // 3. 监听主题切换按钮 (AstroPaper 专属 ID)
    const themeBtn = document.querySelector('#theme-btn');
    if (themeBtn) {
      themeBtn.addEventListener('click', () => {
        // 给个微小的延迟，等待 AstroPaper 切换 data-theme
        setTimeout(() => {
          const nowDark = document.documentElement.getAttribute('data-theme') === 'dark';
          artalk.setDarkMode(nowDark);
        }, 50);
      });
    }

    // 4. 将实例挂载到 window，方便调试或防止重复初始化
    window.artalkInstance = artalk;
  }

  // 响应 Astro 视图切换
  document.addEventListener('astro:page-load', () => {
    // 如果已有实例，先销毁旧的
    if (window.artalkInstance) {
        window.artalkInstance.destroy();
    }
    initArtalk();
  });
</script>

<style is:global>
  /* 解决 Artalk 在 AstroPaper 中的样式细节问题 */
 .artalk,.atk-layer-wrap {
    --at-color-font: #2a2e2e;
    --at-color-deep: #2a2e2e;
    --at-color-sub: #757575;
    --at-color-grey: #747474;
    --at-color-meta: #697182;
    --at-color-border: #008090;
    --at-color-light: #4285f4;
    --at-color-bg: rgb(233, 237, 237);
    --at-color-bg-transl: rgba(233, 237, 237, .94);
    --at-color-bg-grey: #f3f4f5;
    --at-color-bg-grey-transl: rgba(244, 244, 244, .75);
    --at-color-bg-light: rgba(29, 161, 242, .1);
    --at-color-main: #008090;
    --at-color-red: #ff5652;
    --at-color-pink: #fa5a57;
    --at-color-yellow: #ff7c37;
    --at-color-green: #4caf50;
    --at-color-gradient: linear-gradient(180deg, transparent, rgba(255, 255, 255))
}

.artalk.atk-dark-mode,.atk-layer-wrap.atk-dark-mode {
    --at-color-font: #fff;
    --at-color-deep: #e7e7e7;
    --at-color-sub: #e7e7e7;
    --at-color-grey: #fff;
    --at-color-meta: #fff;
    --at-color-border: #2d3235;
    --at-color-light: #687a86;
    --at-color-bg: #1e2224;
    --at-color-bg-transl: rgba(30, 34, 36, .95);
    --at-color-bg-grey: #46494e;
    --at-color-bg-grey-transl: rgba(8, 8, 8, .95);
    --at-color-bg-light: rgba(29, 161, 242, .1);
    --at-color-main: #008090;
    --at-color-red: #ff5652;
    --at-color-pink: #fa5a57;
    --at-color-yellow: #ff7c37;
    --at-color-green: #4caf50;
    --at-color-gradient: linear-gradient(180deg, transparent, rgba(30, 34, 36, 1))
}
  
  /* 确保评论框不会被主题的背景色遮挡或显得突兀 */
  .atk-main-editor, .atk-layer-wrap {
    border-radius: 8px !important;
  }
</style>