---
/* src/components/Comments.astro */
---

<div class="mt-8">
  <div id="artalk-comments"></div>
</div>

<link href="https://artalk.howardzhao.com/dist/Artalk.css" rel="stylesheet">
<script src="https://artalk.howardzhao.com/dist/Artalk.js"></script>

<script is:inline>
  function initArtalk() {
    const el = document.querySelector('#artalk-comments');
    if (!el || typeof Artalk === 'undefined') return;

    // 1. 获取当前 AstroPaper 的主题状态
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    // 2. 实例化
    const artalk = Artalk.init({
      el: '#artalk-comments',
      pageKey: window.location.pathname,
      pageTitle: document.title,
      server: 'https://artalk.howardzhao.com', // 替换为你的服务器地址
      site: 'HZ',
      darkMode: isDark,
    });

    // 3. 监听主题切换按钮 (AstroPaper 专属 ID)
    const themeBtn = document.querySelector('#theme-btn');
    if (themeBtn) {
      themeBtn.addEventListener('click', () => {
        // 给个微小的延迟，等待 AstroPaper 切换 data-theme
        setTimeout(() => {
          const nowDark = document.documentElement.getAttribute('data-theme') === 'dark';
          artalk.setDarkMode(nowDark);
        }, 50);
      });
    }

    // 4. 将实例挂载到 window，方便调试或防止重复初始化
    window.artalkInstance = artalk;
  }

  // 响应 Astro 视图切换
  document.addEventListener('astro:page-load', () => {
    // 如果已有实例，先销毁旧的
    if (window.artalkInstance) {
        window.artalkInstance.destroy();
    }
    initArtalk();
  });
</script>

<style is:global>
  
  /* 确保评论框不会被主题的背景色遮挡或显得突兀 */
  .atk-main-editor, .atk-layer-wrap {
    border-radius: 8px !important;
  }

  /* 当 data-theme 为 light 或 dark 时，Artalk 会自动适应 */
  .artalk {
    
    --at-color-font: var(--color-fill);
    margin-bottom: 2rem;

    --at-color-bg: #e9eded;             /* 评论区底色 */
    
    /* 品牌色/强调色 (同步 AstroPaper 的链接与按钮颜色) */
    --at-color-main: #008090;         /* 提交按钮、链接颜色 */
    
    /* 边框与线 */
    --at-color-border: #008090; /* 分割线 */
    
  }

  /* 细节微调：让 Artalk 看起来更像 AstroPaper 的一部分 */
  .atk-main-editor {
    @apply border border-skin-line rounded-lg !important;
    background: transparent !important;
  }

  .atk-send-btn {
    @apply font-bold !important;
    border-radius: 4px !important;
  }

  /* 修复暗黑模式下的阴影和层级 */
  [data-theme="dark"] .artalk {
    --at-color-bg: #161616; /* 稍微深一点，或者直接用 var(--color-fill) */
    --at-color-light: #1d1d1d;
  }
</style>